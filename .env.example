# Trello API credentials.
# Key:   https://trello.com/app-key
# Token: click "Generate a manually-approved Token" on the same page.
TRELLO_KEY=
TRELLO_TOKEN=

# Skip TUI diff confirm in `rbxtrello sync` (auto-confirm all changes).
# CLI flag `-a` / `--auto-confirm` takes precedence over this.
# RBXTRELLO_AUTO_CONFIRM=true
